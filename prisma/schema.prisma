
generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
  FINANCE
}

enum AssetStatus {
  ACTIVE
  UNDER_REPAIR
  FAULTY
  IN_STORAGE
  MISSING
  DISPOSED
  DONATED
  SOLD
}

enum AssetRequestStatus {
  PENDING
  APPROVED
  REJECTED
  FULFILLED
}

enum AssetRequestUrgency {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

enum DisposalMethod {
  DONATED
  SOLD
  DISPOSED
}

enum DepreciationMethod {
  STRAIGHT_LINE
}

enum AssetCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  CRITICAL
}

enum MovementType {
  BRANCH_TRANSFER
  STORAGE_TRANSFER
  STAFF_ASSIGNMENT
  ROOM_TRANSFER
  SHELF_TRANSFER
  DEPARTMENT_TRANSFER
}

enum DocumentType {
  RECEIPT
  WARRANTY_CARD
  MANUAL
  SERVICE_REPORT
  MAINTENANCE_INVOICE
  OTHER
}

enum ReminderType {
  WARRANTY_EXPIRY
  REPLACEMENT_DUE
  MAINTENANCE_DUE
}

enum RecommendationState {
  HEALTHY
  APPROACHING
  OVERDUE
}

enum PermissionEffect {
  ALLOW
  DENY
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String
  emailVerified Boolean
  image         String?
  phoneNumber   String?
  role          UserRole  @default(STAFF)
  isActive      Boolean   @default(true)
  branchId      String?
  organizationId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  branch        Branch?    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  organization  Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  assignedAssets Asset[]   @relation("AssetCustodian")
  movementLogs  AssetMovement[] @relation("MovedByUser")
  notifications NotificationLog[]
  auditLogs     AuditLog[]
  staffProfile  StaffProfile?
  assetRequestsSubmitted AssetRequest[] @relation("AssetRequestRequester")
  assetRequestsReviewed  AssetRequest[] @relation("AssetRequestReviewer")
  disposalRecords        AssetDisposalRecord[]
  @@unique([email])
  @@index([branchId])
  @@index([organizationId])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("account")
}


model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
  @@index([identifier])
}

model Organization {
  id                              String                 @id @default(cuid())
  name                            String
  settings                        Json?
  maintenanceCostThresholdPercent Int                    @default(50)
  createdAt                       DateTime               @default(now())
  updatedAt                       DateTime               @updatedAt
  branches                        Branch[]
  users                           User[]
  replacementPolicies             ReplacementPolicy[]
  depreciationPolicies            DepreciationPolicy[]
  assets                          Asset[]
  assetRequests                   AssetRequest[]
  disposalRecords                 AssetDisposalRecord[]
  @@unique([name])
}

model Branch {
  id             String           @id @default(cuid())
  organizationId String
  name           String
  code           String
  address        String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departments    Department[]
  rooms          Room[]
  users          User[]
  assets         Asset[]
  assetRequests  AssetRequest[]
  @@unique([organizationId, code])
  @@index([organizationId, name])
}

model Department {
  id        String   @id @default(cuid())
  branchId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branch        Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  assets        Asset[]
  assetRequests AssetRequest[]
  @@unique([branchId, name])
}

model Room {
  id        String   @id @default(cuid())
  branchId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  shelves   Shelf[]
  assets    Asset[]
  @@unique([branchId, name])
}

model Shelf {
  id        String   @id @default(cuid())
  roomId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  assets    Asset[]
  @@unique([roomId, name])
}

model Category {
  id                    String              @id @default(cuid())
  name                  String
  replacementYears      Int
  disposalGraceMonths   Int                @default(6)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  assets                Asset[]
  replacementPolicies   ReplacementPolicy[]
  depreciationPolicies  DepreciationPolicy[]
  assetRequests         AssetRequest[]
  @@unique([name])
}

model Vendor {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assets    Asset[]
  @@unique([name])
}

model StaffProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  employeeCode String   @unique
  title        String?
  department   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Asset {
  id                    String                   @id @default(cuid())
  ain                   String
  serialNumber          String
  name                  String
  description           String?
  status                AssetStatus              @default(ACTIVE)
  condition             AssetCondition           @default(GOOD)
  purchaseDate          DateTime
  purchaseCost          Decimal                  @db.Decimal(12, 2)
  warrantyExpiryDate              DateTime?
  depreciationUsefulLifeYears     Int?
  depreciationSalvageValue        Decimal?                 @db.Decimal(12, 2)
  depreciationMethodOverride      DepreciationMethod?
  isActive                        Boolean                  @default(true)
  branchId                        String
  departmentId          String?
  roomId                String?
  shelfId               String?
  categoryId            String
  vendorId              String?
  custodianId           String?
  organizationId        String
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  branch                Branch                   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  department            Department?              @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  room                  Room?                    @relation(fields: [roomId], references: [id], onDelete: SetNull)
  shelf                 Shelf?                   @relation(fields: [shelfId], references: [id], onDelete: SetNull)
  category              Category                 @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  vendor                Vendor?                  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  custodian             User?                    @relation("AssetCustodian", fields: [custodianId], references: [id], onDelete: SetNull)
  organization          Organization             @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  photos                AssetPhoto[]
  documents             AssetDocument[]
  movements             AssetMovement[]
  statusHistory         AssetStatusHistory[]
  maintenanceRecords    MaintenanceRecord[]
  conditionFlags        ConditionFlag[]
  replacementEvaluations ReplacementEvaluation[]
  disposalRecommendations DisposalRecommendation[]
  disposalRecord         AssetDisposalRecord?
  fulfilledRequest       AssetRequest?
  @@unique([ain])
  @@unique([serialNumber])
  @@index([branchId, status, updatedAt])
  @@index([custodianId])
  @@index([categoryId, purchaseDate])
  @@index([organizationId, ain])
}

model AssetPhoto {
  id        String   @id @default(cuid())
  assetId   String
  url       String
  fileName  String
  createdAt DateTime @default(now())
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@index([assetId, createdAt])
}

model AssetDocument {
  id                  String             @id @default(cuid())
  assetId             String
  documentType        DocumentType
  fileUrl             String
  fileName            String
  mimeType            String
  uploadedByUserId    String
  maintenanceRecordId String?
  createdAt           DateTime           @default(now())
  asset               Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  maintenanceRecord   MaintenanceRecord? @relation(fields: [maintenanceRecordId], references: [id], onDelete: SetNull)
  @@index([assetId, documentType, createdAt])
  @@index([maintenanceRecordId])
}

model AssetMovement {
  id             String       @id @default(cuid())
  assetId        String
  fromBranchId   String?
  toBranchId     String?
  fromRoomId     String?
  toRoomId       String?
  fromShelfId    String?
  toShelfId      String?
  fromCustodianId  String?
  toCustodianId    String?
  fromDepartmentId String?
  toDepartmentId   String?
  movementType     MovementType
  note           String?
  movedByUserId  String
  createdAt      DateTime     @default(now())
  asset          Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  movedBy        User         @relation("MovedByUser", fields: [movedByUserId], references: [id], onDelete: Restrict)
  @@index([assetId, createdAt])
  @@index([toBranchId, createdAt])
}

model AssetStatusHistory {
  id         String      @id @default(cuid())
  assetId    String
  fromStatus AssetStatus?
  toStatus   AssetStatus
  note       String?
  createdAt  DateTime    @default(now())
  asset      Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@index([assetId, createdAt])
}

model MaintenanceRecord {
  id               String             @id @default(cuid())
  assetId          String
  serviceDate      DateTime
  description      String
  cost             Decimal?           @db.Decimal(12, 2)
  vendorName       String?
  nextServiceDate  DateTime?
  status           MaintenanceStatus  @default(COMPLETED)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  asset            Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  documents        AssetDocument[]
  @@index([assetId, serviceDate])
  @@index([assetId, status])
}

model ConditionFlag {
  id         String    @id @default(cuid())
  assetId    String
  title      String
  severity   String
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  asset      Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@index([assetId, resolvedAt, createdAt])
}

model ReplacementPolicy {
  id                 String    @id @default(cuid())
  organizationId     String
  categoryId         String
  replacementYears   Int
  disposalGraceMonths Int      @default(6)
  isDefault          Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category           Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  @@unique([organizationId, categoryId])
}

model ReplacementEvaluation {
  id                     String              @id @default(cuid())
  assetId                String
  expectedEndOfLifeDate  DateTime
  recommendedReplaceDate DateTime
  disposalEligibleDate   DateTime
  state                  RecommendationState
  estimatedReplacementCost Decimal          @db.Decimal(12, 2)
  calculatedAt           DateTime            @default(now())
  asset                  Asset               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@index([recommendedReplaceDate, state])
  @@index([assetId, calculatedAt])
}

model BudgetForecastSnapshot {
  id                   String   @id @default(cuid())
  organizationId       String
  branchId             String?
  periodStart          DateTime
  periodEnd            DateTime
  totalAssetsDue       Int
  estimatedTotalCost   Decimal  @db.Decimal(14, 2)
  createdAt            DateTime @default(now())
  @@index([organizationId, periodStart, periodEnd])
  @@index([branchId, periodStart])
}

model DisposalRecommendation {
  id            String              @id @default(cuid())
  assetId       String
  state         RecommendationState
  recommendedAt DateTime
  reason        String
  createdAt     DateTime            @default(now())
  asset         Asset               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@index([assetId, recommendedAt])
}

model DepreciationPolicy {
  id               String             @id @default(cuid())
  organizationId   String
  categoryId       String
  method           DepreciationMethod @default(STRAIGHT_LINE)
  usefulLifeYears  Int
  salvagePercent   Decimal            @default(10) @db.Decimal(5, 2)
  isDefault        Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category         Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  @@unique([organizationId, categoryId])
}

model AssetDisposalRecord {
  id                    String         @id @default(cuid())
  assetId               String         @unique
  organizationId        String
  method                DisposalMethod
  disposalDate          DateTime
  reason                String
  salePrice             Decimal?       @db.Decimal(12, 2)
  buyerName             String?
  buyerContact          String?
  bookValueAtDisposal   Decimal        @db.Decimal(12, 2)
  recommendedSalePrice  Decimal?       @db.Decimal(12, 2)
  disposedByUserId      String
  createdAt             DateTime       @default(now())
  asset                 Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  organization          Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  disposedBy            User           @relation(fields: [disposedByUserId], references: [id], onDelete: Restrict)
  @@index([organizationId, disposalDate])
  @@index([method, disposalDate])
}

model AssetRequest {
  id               String              @id @default(cuid())
  requesterId      String
  organizationId   String
  branchId         String
  departmentId     String?
  categoryId       String
  reason           String
  urgency          AssetRequestUrgency @default(MEDIUM)
  notes            String?
  status           AssetRequestStatus  @default(PENDING)
  reviewerId       String?
  reviewComment    String?
  reviewedAt       DateTime?
  fulfilledAssetId String?             @unique
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  requester        User                @relation("AssetRequestRequester", fields: [requesterId], references: [id], onDelete: Restrict)
  reviewer         User?               @relation("AssetRequestReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch           Branch              @relation(fields: [branchId], references: [id], onDelete: Restrict)
  department       Department?         @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  category         Category            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  fulfilledAsset   Asset?              @relation(fields: [fulfilledAssetId], references: [id], onDelete: SetNull)
  @@index([organizationId, status, createdAt])
  @@index([branchId, status])
  @@index([requesterId, createdAt])
}

model Permission {
  id          String           @id @default(cuid())
  role        UserRole
  key         String
  effect      PermissionEffect @default(ALLOW)
  createdAt   DateTime         @default(now())
  @@unique([role, key])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  organizationId String?
  branchId     String?
  action       String
  entityType   String
  entityId     String?
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  actor        User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  @@index([organizationId, createdAt])
  @@index([branchId, createdAt])
  @@index([entityType, entityId])
}

model ReminderSchedule {
  id             String       @id @default(cuid())
  organizationId String
  reminderType   ReminderType
  targetDate     DateTime
  payload        Json
  sentAt         DateTime?
  createdAt      DateTime     @default(now())
  @@index([organizationId, reminderType, targetDate])
}

model NotificationLog {
  id        String   @id @default(cuid())
  userId    String
  type      String
  subject   String
  body      String
  sentAt    DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, sentAt])
}

model ImportJob {
  id             String   @id @default(cuid())
  organizationId String
  branchId       String?
  createdByUserId String
  fileName       String
  totalRows      Int
  successRows    Int      @default(0)
  failedRows     Int      @default(0)
  status         String
  errorReport    Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@index([organizationId, createdAt])
}
